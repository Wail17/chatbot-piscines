# --- Python / venv / IDE
__pycache__/
*.py[cod]
.venv/
venv/
.env
*.log
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- Données locales : IGNORER TOUT par défaut
app/store/chroma/
app/store/feedback/
app/store/raw_docs/
app/data/**

# --- Réautoriser uniquement app/data/all/** et faq_images
!app/data/
!app/data/all/
!app/data/all/**
!app/data/faq_images/
!app/data/faq_images/**

# --- On ignorait pdf/docx partout dans app...
app/**/*.pdf
app/**/*.docx

# --- ...mais on les autorise dans /all
!app/data/all/**/*.pdf
!app/data/all/**/*.docx
!app/data/all/**/*.txt

# --- OS / divers
*.tmp
app/store/
