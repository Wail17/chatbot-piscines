# --- Données locales (tout ignorer par défaut)
app/store/chroma/
app/store/feedback/
app/store/raw_docs/
app/data/**

# Réautoriser uniquement app/data/all/**
!app/data/
!app/data/all/
!app/data/all/**

# Ces deux règles ignorent pdf/docx partout...
app/**/*.pdf
app/**/*.docx
# ...mais on les réautorise dans app/data/all
!app/data/all/**/*.pdf
!app/data/all/**/*.docx
!app/data/all/**/*.txt
